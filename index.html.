<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Put A Finger Down: Uncensored</title>
    <style>
        * {
            /* Mobile fixes: prevents blue highlight on tap and text selection while playing */
            -webkit-tap-highlight-color: transparent;
            -webkit-touch-callout: none;
            user-select: none;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            background: linear-gradient(180deg, #000000 0%, #666666 100%);
            height: 100vh;
            margin: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: flex-start;
            padding-top: 40px;
            overflow: hidden;
        }

        .btn-next {
            background: #ffffff;
            color: #000000;
            border: none;
            padding: 20px 60px;
            border-radius: 15px;
            font-weight: 900;
            font-size: 1.2rem;
            margin-bottom: 30px;
            box-shadow: 0 10px 20px rgba(0,0,0,0.5);
            z-index: 10;
            cursor: pointer;
            transition: transform 0.1s;
        }

        .btn-next:active {
            transform: scale(0.95);
            background: #e74c3c;
            color: white;
        }

        .card-container {
            width: 85vw;
            height: 60vh;
            perspective: 1000px;
        }

        .card-inner {
            position: relative;
            width: 100%;
            height: 100%;
            transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
            transform-style: preserve-3d;
        }

        .card-container.flipped .card-inner {
            transform: rotateY(180deg);
        }

        .card-face {
            position: absolute;
            width: 100%;
            height: 100%;
            backface-visibility: hidden;
            border-radius: 25px;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 30px;
            box-sizing: border-box;
            box-shadow: 0 20px 50px rgba(0,0,0,0.6);
            text-align: center;
        }

        .card-front {
            background: linear-gradient(135deg, #000000 0%, #333333 100%);
            color: white;
            font-size: 4rem;
            border: 1px solid rgba(255,255,255,0.2);
        }

        .card-back {
            background: #ffffff;
            color: #000000;
            transform: rotateY(180deg);
            font-size: 1.6rem;
            font-weight: 800;
        }
    </style>
</head>
<body>

    <button class="btn-next" onclick="newQuestion()">NEXT CARD</button>

    <div class="card-container" id="card" onclick="this.classList.toggle('flipped')">
        <div class="card-inner">
            <div class="card-face card-front">?</div>
            <div class="card-face card-back" id="cardText">TAP THE CARD TO REVEAL</div>
        </div>
    </div>

    <script>
        const questions = [
            "Put a finger down if you've ever shit in the woods.",
            "Put a finger down if you've ever accidentally sent a nude to a family member.",
            "Put a finger down if you've ever used a sock as toilet paper.",
            "Put a finger down if you've ever hooked up with a co-worker in the office.",
            "Put a finger down if you've ever been caught doing the deed in a car.",
            "Put a finger down if you've ever peed in a bottle because you were too lazy to get up.",
            "Put a finger down if you've ever lied about having a dead relative to get out of work.",
            "Put a finger down if you've ever stalked an ex from a fake account."
        ];

        function newQuestion() {
            const card = document.getElementById('card');
            const cardText = document.getElementById('cardText');
            
            // Unflip first
            card.classList.remove('flipped');
            
            // Change text while it's hidden (small delay)
            setTimeout(() => {
                const random = Math.floor(Math.random() * questions.length);
                cardText.innerText = questions[random];
            }, 200);
        }
    </script>
</body>
</html>
